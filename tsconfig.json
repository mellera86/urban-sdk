{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@components/*": ["./app/components/*"],
      "@models/*": ["./app/api/models/*"],
      "@actions/*": ["./app/api/actions/*"],
      "@utils/*": ["./app/utils/*"],
      "@api-hooks/*": ["./app/api/hooks/*"],
      "@styles/*": ["./app/styles/*"],
      "@features/*": ["./app/features/*"],
      "@providers/*": ["./app/providers/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
